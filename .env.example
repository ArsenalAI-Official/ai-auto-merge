# GitHub App Credentials
# Get these from https://github.com/settings/apps/your-app-name
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...your private key here...
-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Anthropic API Key
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server Config
PORT=3000
NODE_ENV=development

# Optional: Redis URL for BullMQ job queue (recommended for production).
# Without this, jobs run in-process with no persistence or retry.
# REDIS_URL=redis://localhost:6379

# Auto-merge settings
# If true, auto-merge the PR after conflict resolution + CI passes
# If false, just resolve conflicts and let the author merge manually
AUTO_MERGE_ON_CI_PASS=false

# Minimum confidence threshold for auto-applying resolution without comment
# Values: "high" | "medium" | "low"
AUTO_APPLY_CONFIDENCE_THRESHOLD=high

# Max files to auto-resolve per PR (large PRs need careful review)
MAX_FILES_TO_AUTO_RESOLVE=20
